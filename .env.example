# Copia este fichero a ".env" y rellena los valores.
# En Expo, las variables con prefijo EXPO_PUBLIC_ se inyectan en la app.

# TMDB — "API Read Access Token" (v4). Se obtiene gratis en:
#   https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_ACCESS_TOKEN=

# Supabase — Settings > API en tu proyecto (https://supabase.com)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
